# ──────────────────────────────────────────────────────────────────────────────
# Bloom Together — environment variables
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below.
# 3. .env is git-ignored — never commit it.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
# Replace USER, PASSWORD, and DBNAME with your PostgreSQL credentials.
#
# Docker quickstart (no installation required):
#   docker run -d --name bloom-pg \
#     -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=bloom \
#     -p 5432:5432 postgres:16-alpine
#   → DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bloom
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/bloom

# ── Auth (required) ───────────────────────────────────────────────────────────
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string

# ── AI generation (optional) ─────────────────────────────────────────────────
# When absent the app returns five static task templates — fully functional.
ANTHROPIC_API_KEY=

# ── Server (optional — defaults shown) ───────────────────────────────────────
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# ── Dev-only auto-login (frontend) ────────────────────────────────────────────
# Home.vue silently logs in as this user to fetch real garden data.
# Remove once a proper login page is wired up.
VITE_DEV_USERNAME=mario
VITE_DEV_PASSWORD=1234
